ECKIT-166.x: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 ECKIT-166.x
.PHONY : ECKIT-166.x

# fast build rule for target.
ECKIT-166.x/fast:
	$(MAKE) $(MAKESILENT) -f regressions/CMakeFiles/ECKIT-166.x.dir/build.make regressions/CMakeFiles/ECKIT-166.x.dir/build
.PHONY : ECKIT-166.x/fast

