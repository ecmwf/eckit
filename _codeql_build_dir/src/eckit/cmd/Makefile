	cd /home/runner/work/eckit/eckit/_codeql_build_dir && $(MAKE) $(MAKESILENT) -f src/eckit/cmd/CMakeFiles/eckit_cmd.dir/build.make src/eckit/cmd/CMakeFiles/eckit_cmd.dir/UserInput.cc.i
.PHONY : UserInput.cc.i

