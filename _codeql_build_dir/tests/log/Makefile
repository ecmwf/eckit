	cd /home/runner/work/eckit/eckit/_codeql_build_dir && $(MAKE) $(MAKESILENT) -f tests/log/CMakeFiles/eckit_test_syslog.dir/build.make tests/log/CMakeFiles/eckit_test_syslog.dir/test_syslog.cc.o
.PHONY : test_syslog.cc.o

test_syslog.i: test_syslog.cc.i
.PHONY : test_syslog.i

# target to preprocess a source file
test_syslog.cc.i:
	cd /home/runner/work/eckit/eckit/_codeql_build_dir && $(MAKE) $(MAKESILENT) -f tests/log/CMakeFiles/eckit_test_syslog.dir/build.make tests/log/CMakeFiles/eckit_test_syslog.dir/test_syslog.cc.i
.PHONY : test_syslog.cc.i

test_syslog.s: test_syslog.cc.s
.PHONY : test_syslog.s

# target to generate assembly for a file
test_syslog.cc.s:
	cd /home/runner/work/eckit/eckit/_codeql_build_dir && $(MAKE) $(MAKESILENT) -f tests/log/CMakeFiles/eckit_test_syslog.dir/build.make tests/log/CMakeFiles/eckit_test_syslog.dir/test_syslog.cc.s
.PHONY : test_syslog.cc.s

